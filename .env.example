# Moodle base URL
MOODLE_URL=https://online.aum.edu.mn

# Discord webhook URL for monitor notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# Groq API key (required for /analyze and /analyze_all)
GROQ_API_KEY=gsk_REPLACE_ME

# Discord bot token for slash-command control bot
DISCORD_BOT_TOKEN=REPLACE_ME

# Optional allow-lists (comma-separated numeric Discord IDs)
# Leave empty to allow any user in joined guilds.
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_ROLE_IDS=

# Optional guild ID for fast slash-command sync in development
# If empty, commands sync globally and may take time to appear.
DISCORD_CONTROL_GUILD_ID=
